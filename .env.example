# ===== APPLICATION =====
NODE_ENV=development
PORT=4000

# ===== DATABASE =====
DATABASE_URL="postgresql://postgres@localhost:5432/database_name?schema=public"

# ===== JWT AUTHENTICATION =====
JWT_ACCESS_SECRET=my-super-secure-random-access-secret-key-123
JWT_REFRESH_SECRET=a-different-secure-random-refresh-secret-key-456
JWT_ACCESS_EXPIRATION=172800000
JWT_REFRESH_EXPIRATION=604800000

# ===== STORAGE PROVIDER =====
# Options: 'minio' or 's3'
STORAGE_PROVIDER=minio

# ===== AWS S3 CONFIGURATION (Used for both S3 and MinIO) =====
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=nest-uploads

# ===== MINIO CONFIGURATION =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin